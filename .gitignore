# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
ENV/
env/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.coverage
.coverage.*
.pytest_cache/
htmlcov/

# Type checker cache
.mypy_cache/
.pyright/

# IDEs and editors
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Locally bundled FFmpeg binaries for Windows builds
vendor/ffmpeg/bin/*.exe
vendor/ffmpeg/bin/*.dll
vendor/ffmpeg/bin/*.txt
!vendor/ffmpeg/bin/.gitkeep
